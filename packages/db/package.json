{
  "name": "@boilerplate/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run db:studio",
    "db:generate": "bun with-env drizzle-kit generate",
    "db:migrate": "bun with-env drizzle-kit migrate",
    "db:push": "bun with-env drizzle-kit push",
    "db:pull": "bun with-env drizzle-kit pull",
    "db:studio": "bun with-env drizzle-kit studio",
    "with-env": "dotenv -e ../../.env.local --"
  },
  "dependencies": {
    "@neondatabase/serverless": "catalog:",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "drizzle-query-logger": "^1.1.2",
    "nanoid": "^5.1.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@boilerplate/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "catalog:",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "typescript": "catalog:"
  }
}
